# WrenchIQ — Environment Configuration
# Copy to .env.local and fill in your values before starting the server.

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Your Anthropic API key (required for AI Insights, Recommendations, 3C Writer)
ANTHROPIC_API_KEY=sk-ant-...

# Claude API endpoint — override only if using a proxy or private deployment
# CLAUDE_API_URL=https://api.anthropic.com/v1/messages

# Anthropic API version header
# CLAUDE_API_VERSION=2023-06-01

# Model for Knowledge Graph chat (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL_CHAT=claude-haiku-4-5-20251001

# Model for Recommendations engine (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL_RECOMMENDATIONS=claude-haiku-4-5-20251001

# Token budget overrides (optional)
# CLAUDE_MAX_TOKENS_CHAT=800
# CLAUDE_MAX_TOKENS_RECOMMENDATIONS=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string — local or Atlas
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# Database name
MONGODB_DB=wrenchiq

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001

# Vite exposes this to the browser build
VITE_API_BASE=http://localhost:3001

# Anthropic API key exposed to browser (for 3C Story Writer client-side calls)
VITE_ANTHROPIC_API_KEY=sk-ant-...
